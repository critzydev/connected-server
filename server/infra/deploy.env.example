# Connected relay — the ONE config file. Copy to deploy.env and fill in 3 values.
#   cp deploy.env.example deploy.env && nano deploy.env && ./setup.sh
# Never commit deploy.env (it holds your stream key).

# --- Required ---------------------------------------------------------------

# Your domain. Must have a DNS A record pointing at this VPS before you run setup
# (Caddy needs it to issue the TLS cert). The WHIP ingest URL becomes:
#   https://<DOMAIN>/live/whip
DOMAIN=stream.example.com

# Optional: serve the Connected web app (studio, guest login, donate page)
# from this same box on its own domain — e.g. your apex domain, with the
# relay on a subdomain: WEB_DOMAIN=mystream.com, DOMAIN=connected.mystream.com.
# Point BOTH DNS records at this VPS. Leave empty to skip the web app.
WEB_DOMAIN=

# Twitch dashboard -> Settings -> Stream -> Primary Stream Key.
# OPTIONAL since the Twitch link exists: leave this EMPTY and link your
# Twitch account in web Settings instead — the relay then fetches (and
# auto-rotates) the key itself. Set it here only if you prefer not to link.
TWITCH_STREAM_KEY=

# Which brand this deploy is ("connected" unless you have a custom brand).
# Drives the web app's look AND the BRB card theme below. See brands/.
BRAND=connected

# --- Auto-detected (leave blank unless detection is wrong) ------------------

# The VPS public IP, advertised to browsers for direct WebRTC media. setup.sh
# auto-detects this; only set it by hand if your box is behind extra NAT.
PUBLIC_IP=

# --- Studio (session hub: chat, alerts, donations, TTS — docs/STUDIO.md) ----

# The code every device in your rig joins the session with. setup.sh generates
# a random one on first run if you leave this empty. Enter the same code in the
# app's Settings -> Studio on each phone.
SESSION_CODE=

# Twitch channel whose chat the hub reads (anonymous, no OAuth). Usually your
# own channel. Devices can also set it from the app.
TWITCH_CHANNEL=

# Optional: a Twitch application client id (dev.twitch.tv/console, client type
# PUBLIC — no secret). Unlocks the Twitch link in Settings: EventSub alerts
# for follows + EVERY channel-point redemption (incl. sound-effect rewards
# with no text), and per-reward sound uploads. Can also be pasted in the web
# Settings instead of here.
TWITCH_CLIENT_ID=

# Donations via YOUR OWN Stripe account (money goes straight to you; card data
# stays on Stripe's hosted page). Create an account at stripe.com, then:
#   secret key:      dashboard.stripe.com -> Developers -> API keys
#   webhook secret:  Developers -> Webhooks -> Add endpoint
#                    URL: https://<DOMAIN>/hub/webhooks/stripe
#                    Event: checkout.session.completed
# Leave empty to keep donations off.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DONATION_CURRENCY=usd
DONATION_MIN_CENTS=100        # smallest donation ($1)
DONATION_MEDIA_MIN_CENTS=500  # donations at/above this can attach a YouTube link
# Where donors land after paying — your web app's /donate page. Defaults to
# https://<DOMAIN>/donate; set this if the web app lives on another domain.
PUBLIC_WEB_ORIGIN=

# --- Never-cut-out tuning (sane defaults; edit only if you know why) --------

GRACE=120          # seconds a DROPPED phone may be gone before the broadcast ends
END_LINGER=10      # seconds after you tap End Stream before the broadcast closes
                   # (a clean end is detected instantly; this is just flap insurance)
VBITRATE=4500k     # output video bitrate (match your relay uplink)
W=1280
H=720
FPS=30
BRB_TEXT=Reconnecting…

# BRB card colors (ffmpeg 0xRRGGBB). setup.sh themes these from BRAND, but you
# can override here. Defaults shown are the Connected palette.
# BRB_BG=0x140a23
# BRB_FG=0xEDE8FF

# Custom BRB card: drop an image (png/jpg) or a video (looped forever, audio
# kept if it has any) into server/infra/relay/brb-media/ and point at it by its
# in-container path. Unset = the classic color+text card above.
# BRB_MEDIA=/brb-media/card.mp4
